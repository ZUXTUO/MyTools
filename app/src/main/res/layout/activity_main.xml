<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:letterSpacing="0.3"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="32dp"
            android:layout_gravity="center" />

        <!-- Grid Layout -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:alignmentMode="alignMargins"
            android:rowOrderPreserved="false">

            <!-- Settings App -->
            <LinearLayout
                android:id="@+id/app_settings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_settings"
                    android:padding="16dp"
                    android:background="@drawable/bg_circle_button"
                    app:tint="@color/color_on_accent" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Brightness App -->
            <LinearLayout
                android:id="@+id/app_brightness"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_brightness"
                    android:padding="16dp"
                    android:background="@drawable/bg_circle_button"
                    app:tint="@color/color_on_accent" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brightness_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Volume App -->
            <LinearLayout
                android:id="@+id/app_volume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_volume"
                    android:padding="16dp"
                    android:background="@drawable/bg_circle_button"
                    app:tint="@color/color_on_accent" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/volume_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Random App -->
            <LinearLayout
                android:id="@+id/app_random"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_random"
                    android:padding="16dp"
                    android:background="@drawable/bg_circle_button"
                    app:tint="@color/color_on_accent" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/random_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Anti-Motion Sickness -->
            <LinearLayout
                android:id="@+id/app_anti_motion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_anti_motion"
                    android:padding="16dp"
                    android:background="@drawable/bg_circle_button"
                    app:tint="@color/color_on_accent" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/anti_motion_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- AI Chat App -->
            <LinearLayout
                android:id="@+id/app_ai_chat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_ai"
                    android:padding="16dp"
                    android:background="@drawable/bg_circle_button"
                    app:tint="@color/color_on_accent" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_chat_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Dice Roller App -->
            <LinearLayout
                android:id="@+id/app_dice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_dice"
                    android:padding="16dp"
                    android:background="@drawable/bg_circle_button"
                    app:tint="@color/color_on_accent" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dice_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </GridLayout>

    </LinearLayout>
</ScrollView>
