<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingBottom="48dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="64dp"
            android:layout_marginBottom="64dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:letterSpacing="0.4"
                android:fontFamily="sans-serif-light" />
            
            <View
                android:layout_width="40dp"
                android:layout_height="1dp"
                android:background="@color/card_border"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- Controls Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Brightness Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="56dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brightness_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brightness_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="24dp" />

                <SeekBar
                    android:id="@+id/brightness_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="100"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:splitTrack="false"
                    android:progressDrawable="@drawable/custom_seekbar_track"
                    android:thumb="@drawable/custom_seekbar_thumb" />
                
                <TextView
                    android:id="@+id/brightness_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@color/primary"
                    android:textSize="10sp"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Volume Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="56dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/volume_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/volume_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="24dp" />

                <SeekBar
                    android:id="@+id/volume_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="100"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:splitTrack="false"
                    android:progressDrawable="@drawable/custom_seekbar_track"
                    android:thumb="@drawable/custom_seekbar_thumb" />
                
                <TextView
                    android:id="@+id/volume_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@color/primary"
                    android:textSize="10sp"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Random Number Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_premium_card"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/random_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/random_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginBottom="32dp" />

                <TextView
                    android:id="@+id/random_result_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="?"
                    android:textColor="@color/text_primary"
                    android:textSize="48sp"
                    android:fontFamily="sans-serif-thin"
                    android:layout_marginBottom="32dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_generate_random"
                    android:layout_width="160dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_gradient_button"
                    android:text="@string/random_btn"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
